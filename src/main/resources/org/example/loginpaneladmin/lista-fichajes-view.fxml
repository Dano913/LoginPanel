<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.loginpaneladmin.controller.FichajesController">

    <!-- 🔵 TÍTULO ARRIBA -->
    <top>
        <Label text="Lista de Fichajes"
               style="-fx-font-size: 18px; -fx-padding: 15;" />
    </top>

    <!-- 📊 TABLA CENTRO -->
    <center>
        <TableView fx:id="tableFichajes">

            <columns>

                <!-- Código -->
                <TableColumn fx:id="colCodigo"
                             text="Código"
                             prefWidth="100"/>

                <!-- Fecha -->
                <TableColumn fx:id="colFecha"
                             text="Fecha"
                             prefWidth="180"/>

                <!-- Nombre -->
                <TableColumn fx:id="colNombre"
                             text="Nombre"
                             prefWidth="200"/>

                <!-- Tipo (Entrada / Salida) -->
                <TableColumn fx:id="colTipo"
                             text="Tipo"
                             prefWidth="120"/>

            </columns>

        </TableView>
    </center>

</BorderPane>