<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.loginpaneladmin.controller.DetalleEmpleadoController">

    <!-- 🟦 HEADER -->
    <top>
        <Label fx:id="titleLabel"
               text="Perfil del Empleado"
               style="-fx-font-size: 18px; -fx-padding: 15;" />
    </top>

    <!-- 👤 DATOS EMPLEADO -->
    <left>
        <VBox spacing="10" style="-fx-padding: 15;">
            <Label text="Datos personales" style="-fx-font-weight: bold;"/>

            <Label fx:id="nameLabel" text="Nombre:"/>
            <Label fx:id="ageLabel" text="Edad:"/>
            <Label fx:id="genderLabel" text="Género:"/>
            <Label fx:id="emailLabel" text="Email:"/>
            <Label fx:id="phoneLabel" text="Teléfono:"/>
            <Label fx:id="departmentLabel" text="Departamento:"/>
            <Label fx:id="roleLabel" text="Cargo:"/>
        </VBox>
    </left>

    <!-- 📋 REGISTROS DE FICHAJE -->
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">

            <Label text="Registros de fichaje"
                   style="-fx-font-weight: bold;"/>

            <TableView fx:id="attendanceTable">

                <columns>
                    <TableColumn fx:id="dateColumn" text="Fecha" prefWidth="150"/>
                    <TableColumn fx:id="typeColumn" text="Tipo" prefWidth="120"/>
                    <TableColumn fx:id="timeColumn" text="Hora" prefWidth="120"/>
                </columns>

            </TableView>

        </VBox>
    </center>

    <!-- 🔘 ACCIONES -->
    <bottom>
        <HBox spacing="10" style="-fx-padding: 10;" alignment="CENTER_RIGHT">
            <Button text="Editar datos" onAction="#handleEdit"/>
            <Button text="Cerrar" onAction="#handleClose"/>
        </HBox>
    </bottom>

</BorderPane>