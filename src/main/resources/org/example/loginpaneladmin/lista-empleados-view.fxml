<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.loginpaneladmin.controller.ListaEmpleadoController">

    <!-- 🔵 TÍTULO -->
    <top>
        <Label text="Lista de Empleados"
               style="-fx-font-size: 18px; -fx-padding: 15;" />
    </top>

    <!-- 📊 TABLA -->
    <center>
        <TableView fx:id="tableEmpleados">

            <columns>

                <!-- ID -->
                <TableColumn fx:id="colId"
                             text="ID"
                             prefWidth="100"/>

                <!-- Nombre -->
                <TableColumn fx:id="colNombre"
                             text="Nombre"
                             prefWidth="200"/>

                <!-- Edad -->
                <TableColumn fx:id="colEdad"
                             text="Edad"
                             prefWidth="100"/>

                <!-- Género -->
                <TableColumn fx:id="colGenero"
                             text="Género"
                             prefWidth="120"/>

            </columns>

        </TableView>
    </center>

</BorderPane>